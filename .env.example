PORT=3000
NODE_ENV=development

# Use 127.0.0.1 (not localhost) to avoid IPv6 connection issues on Linux
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=credence_db
DB_USER=root
DB_PASSWORD=rootpassword

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

LOG_LEVEL=info

# Set to true to re-seed even if data exists
SEED_FORCE=false

# Set to false to disable async queue endpoint
USE_QUEUE=true
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672

# Docker MySQL credentials (npm run docker:infra):
# DB_PASSWORD=rootpassword
