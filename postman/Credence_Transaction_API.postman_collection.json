{
  "info": {
    "name": "Credence Transaction API",
    "_postman_id": "credence-txn-api-2026",
    "description": "Credence Full Stack Assignment — Transaction Management Service\n\n## Setup\n1. Import this collection + `Credence_Local.postman_environment.json`\n2. Run **Auth → Login** to save JWT token automatically\n3. Use account ID **101** for assignment examples\n\n## Bonus async flow\n1. Start RabbitMQ: `npm run docker:infra`\n2. Start worker: `npm run worker`\n3. Call **Transactions → Create Transaction (Async)**",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.environment.set('token', res.data.token);",
                  "  console.log('Token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@credence.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction (Sync)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": 101,\n  \"amount\": 5000,\n  \"transactionType\": \"DEBIT\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/transactions"
          }
        },
        {
          "name": "Create Transaction (Async — Queue)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": 101,\n  \"amount\": 1000,\n  \"transactionType\": \"CREDIT\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/transactions/async"
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions?accountId=101&page=1&limit=20&sortBy=createdAt&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "transactions"],
              "query": [
                { "key": "accountId", "value": "101" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortOrder", "value": "desc" },
                { "key": "transactionType", "value": "DEBIT", "disabled": true },
                { "key": "status", "value": "SUCCESS", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Account Summary (ID 101)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/accounts/101/summary"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/health"
          }
        }
      ]
    }
  ]
}
