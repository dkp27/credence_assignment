{
  "name": "credence-transaction-service",
  "version": "1.0.0",
  "description": "Transaction Management Service - Credence Full Stack Assignment",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "setup": "npm install && ts-node src/database/setup.ts",
    "db:setup": "ts-node src/database/setup.ts",
    "db:test": "ts-node src/database/testConnection.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "docker:infra": "docker compose up -d",
    "docker:infra:down": "docker compose down",
    "db:sync": "ts-node src/database/sync.ts",
    "db:seed": "ts-node src/database/seed.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "transaction",
    "nodejs",
    "typescript",
    "sequelize"
  ],
  "license": "MIT",
  "dependencies": {
    "amqplib": "^0.10.9",
    "bcryptjs": "^2.4.3",
    "bunyan": "^1.8.15",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.12.0",
    "sequelize": "^6.37.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/bunyan": "^1.8.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "jest": "^29.7.0",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
